      <aliases enabled='yes' />
      <column caption='ALK fusion status' datatype='integer' name='[ALK_fusion_status]' role='measure' type='quantitative' />
      <column caption='Age Group' datatype='string' name='[Calculation_2254333129441808384]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [patient_age] &lt; 35 THEN &quot;&lt;35&quot;&#13;&#10;&#13;&#10;ELSEIF [patient_age] &gt;= 35 AND [patient_age] &lt;= 44 THEN &quot;35–44&quot;&#13;&#10;&#13;&#10;ELSEIF [patient_age] &gt;= 45 AND [patient_age] &lt;= 54 THEN &quot;45–54&quot;&#13;&#10;&#13;&#10;ELSEIF [patient_age] &gt;= 55 AND [patient_age] &lt;= 64 THEN &quot;55–64&quot;&#13;&#10;&#13;&#10;ELSE &quot;65+&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='KeepRow' datatype='integer' name='[Calculation_2254333129492582402]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_3104387556308451328] = 0 THEN&#13;&#10;    // keep ONLY ONE row per no-treatment patient (choose an anchor treatment name that exists for everyone)&#13;&#10;    IIF([Pivot Field Names] = &quot;chemotherapy_received&quot;, 1, 0)&#13;&#10;&#13;&#10;ELSE&#13;&#10;    // for treated patients, keep only active treatment rows&#13;&#10;    IIF([Pivot Field Values] = 1, 1, 0)&#13;&#10;END' />
      </column>
      <column caption='Treat_label1' datatype='string' name='[Calculation_2254333129493073923]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_3104387556308451328] = 0 THEN &quot;No Treatment&quot;&#13;&#10;ELSE [Calculation_3104387556308697089]&#13;&#10;END' />
        <aliases>
          <alias key='&quot;Chemotherapy Received&quot;' value='Chemotherapy' />
          <alias key='&quot;Immunotherapy Received&quot;' value='Immunotherapy' />
          <alias key='&quot;Radiation Therapy&quot;' value='Radiation' />
          <alias key='&quot;Targeted Therapy Received&quot;' value='Targeted Therapy' />
        </aliases>
      </column>
      <column caption='Patient Survival' datatype='real' name='[Calculation_2254333129493487620]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id] : MIN([survival_time_months]) }' />
      </column>
      <column caption='total_treat_patient' datatype='integer' name='[Calculation_3104387556308451328]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id] : SUM([Pivot Field Values]) }' />
