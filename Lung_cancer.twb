          <datasource-dependencies datasource='federated.03tqwew125w1y9157lijc112vugc'>
            <column caption='KeepRow' datatype='integer' name='[Calculation_2254333129492582402]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_3104387556308451328] = 0 THEN&#13;&#10;    // keep ONLY ONE row per no-treatment patient (choose an anchor treatment name that exists for everyone)&#13;&#10;    IIF([Pivot Field Names] = &quot;chemotherapy_received&quot;, 1, 0)&#13;&#10;&#13;&#10;ELSE&#13;&#10;    // for treated patients, keep only active treatment rows&#13;&#10;    IIF([Pivot Field Values] = 1, 1, 0)&#13;&#10;END' />
            </column>
            <column caption='Patient Survival' datatype='real' name='[Calculation_2254333129493487620]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [id] : MIN([survival_time_months]) }' />
